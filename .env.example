# Firebase Configuration (Required for Google Sign-In and Email Auth)
# Create a Firebase project at https://console.firebase.google.com
# 1. Go to Project Settings > General > Your apps > Web app
# 2. Copy the config values below
# 3. Enable Authentication > Sign-in method > Email/Password AND Google

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Credentials
# Set these to control who can access the admin dashboard.
# You can use any email/password combo here.
# If Firebase is configured, admin can also login with Google (must match this email).
NEXT_PUBLIC_ADMIN_EMAIL=admin@affiliatehub.com
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Note: The app works in DEMO MODE without Firebase credentials.
# In demo mode, signup/login works with local storage only (no real auth).
# Add Firebase credentials to enable:
#   - Google Sign-In
#   - Email/Password authentication
#   - Account conflict detection (same email different providers)

# Supabase (Database - cross-device product storage)
# Create a free project at https://supabase.com
# Go to Project Settings > API to find these values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Razorpay Payment Gateway
# Create account at https://dashboard.razorpay.com
# Go to Settings > API Keys to generate
# NEXT_PUBLIC_ prefix exposes KEY_ID to frontend (required for checkout modal)
# KEY_SECRET stays server-side only (used for order creation & signature verification)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# Shiprocket Delivery Partner (primary - aggregator)
# Create account at https://app.shiprocket.in
SHIPROCKET_EMAIL=your_email@example.com
SHIPROCKET_PASSWORD=your_password

# Delhivery (secondary - for heavy/bulky items like furniture)
# Get API token from https://www.delhivery.com/developers
DELHIVERY_API_TOKEN=your_api_token_here
DELHIVERY_MODE=test

# SMTP Email (for order confirmation & invoices)
# Use any SMTP provider: Gmail, SendGrid, Mailgun, AWS SES, etc.
# For Gmail: host=smtp.gmail.com, port=587, user=your@gmail.com, pass=app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@theideadecorator.com

# PayU Payment Gateway (alternative to Razorpay)
# Create account at https://payu.in/business
# Go to Dashboard > Settings > API Keys
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_MERCHANT_SALT=your_merchant_salt
PAYU_MODE=test
